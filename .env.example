# Copy to .env and adjust. .env is gitignored.

# --- Postgres / TimescaleDB ---
POSTGRES_USER=skalna
POSTGRES_PASSWORD=change-me
POSTGRES_DB=skalna

# DSN used by the portal CLI. Inside compose the host is the service name `db`;
# from the laptop against the published port use localhost.
DATABASE_URL=postgresql://skalna:change-me@db:5432/skalna

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# --- Paths (host side) ---
# Where SD backups are dropped and where the loader reads from.
LANDING_DIR=./landing
BACKUPS_DIR=./backups

# --- Weather scrape ---
WEATHER_STATION=cheb
WEATHER_SOURCE=in-pocasi
