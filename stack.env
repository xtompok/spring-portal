# Portainer stack environment for the Skalná data-portal.
# Portainer substitutes these into docker-compose.yml the same way Compose reads .env.
# Adjust the values below before deploying. Do NOT commit real secrets.

# --- Postgres / TimescaleDB ---
POSTGRES_USER=skalna
POSTGRES_PASSWORD=pQu29TBrsdQdnjnhUwtPrPq
POSTGRES_DB=skalna

# DSN used by the portal CLI and scheduler. Inside the stack the host is the
# service name `db`. Keep user/password/db in sync with the three vars above.
DATABASE_URL=postgresql://skalna:pQu29TBrsdQdnjnhUwtPrPq@db:5432/skalna

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=TwMUpH1MMMuSV3dRQPnr3X4

# --- Paths (Portainer host side) ---
# Bind mounts on the Portainer host. Use absolute paths that exist on the server;
# relative paths resolve against the stack's working dir. These dirs must be
# readable/writable by the containers.
LANDING_DIR=/opt/skalna/landing
BACKUPS_DIR=/opt/skalna/backups

# --- Weather scrape ---
WEATHER_STATION=cheb
WEATHER_SOURCE=in-pocasi
